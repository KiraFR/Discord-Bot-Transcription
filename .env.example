# --- Discord ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optionnel : ID d'un serveur de test pour un enregistrement INSTANTANÉ des
# commandes (sinon enregistrement global, propagation jusqu'à ~1h).
GUILD_ID=

# --- Gemini (Google AI Studio) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Transcription ---
TRANSCRIPT_LANG=français
# Durée de silence (ms) qui clôt une prise de parole.
SILENCE_MS=800
# Dossier de stockage des sessions (audio + transcripts).
STORAGE_DIR=storage
# Optionnel : noms propres / jargon pour aider Gemini (séparés par des virgules).
GLOSSARY=

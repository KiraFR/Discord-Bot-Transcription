# --- Discord ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: a test server ID for INSTANT command registration
# (otherwise commands are registered globally, propagation up to ~1h).
GUILD_ID=

# --- Gemini (Google AI Studio) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Transcription ---
TRANSCRIPT_LANG=French
# Silence (ms) that ends a turn of speech.
SILENCE_MS=800
# Where session data (audio + transcripts) is stored.
STORAGE_DIR=storage
# Optional: proper nouns / jargon to help Gemini (comma-separated).
GLOSSARY=
